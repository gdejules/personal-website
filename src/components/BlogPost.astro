---
const { url, title, date } = Astro.props;
---
<style>
  .list {
    display: flex;
    align-items: start;
    gap: 24px;
  }

  .date {
    max-width: 12ch;
    flex: 0 0 auto;
    font-family: var(--font-lato);
    font-weight: 400;
    font-size: clamp(0.7rem, 0.9rem + 1vw, 1.1rem);
    color: gray;
  }

  .title {
    flex: 1;
  }

  .article-link {
    text-decoration: none;
    color: inherit;
    font-family: var(--font-merriweather);
    font-weight: 500;
    font-size: clamp(0.7rem, 0.9rem + 1vw, 1.1rem);
  }

  .article-link:hover {
    color: var(--secondary-color);
  }
</style>

<div class="list">
  <span class="date">{date}</span>
  <span class="title"><a href={url} class="article-link">{title}</a></span>
</div>