---
const { url, title, date, readTime } = Astro.props;
---
<style>
  .list {
    display: flex;
    flex-direction: column;
    align-items: start;
  }

  .title {
    flex: 1;
  }

  .article-link {
    text-decoration: none;
    color: inherit;
    font-family: var(--font-merriweather);
    font-weight: 500;
    font-size: clamp(0.7rem, 0.9rem + 1vw, 1.1rem);
  }

  .article-link:hover {
    color: var(--secondary-color);
  }
</style>

<div class="list">
  <div class="article-label">
    <span>{date}</span>
    <span>{readTime}</span>
  </div>
  <span class="title"><a href={url} class="article-link">{title}</a></span>
</div>