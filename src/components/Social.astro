---
const { platform, username } = Astro.props;
---
<a href={`https://www.${platform}.com/${username}`}>{platform}</a>

<style>
  a {
    font-size: clamp(1rem, 1.1rem, 1.2rem);
    font-family: var(--font-merriweather);
    font-weight: 500;
    padding: 0.5rem;
    color: var(--primary-color);
    text-decoration: none;
  }
</style>