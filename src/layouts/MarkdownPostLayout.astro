---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
const shorten = {
  year: "numeric",
  month: "short",
  day: "numeric",
};
---

<style>
  a {
    text-decoration: none;
  }

  .tag-list {
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
  }
</style>

<BaseLayout pageTitle={frontmatter.title}>
  <div class="article-label">
    <span>{frontmatter.pubDate.toLocaleDateString("en-US", shorten)}</span>
    <span>{frontmatter.readTime}</span>
  </div>
  <h1 class="article-title">{frontmatter.title}</h1>
  <p><em>{frontmatter.description}</em></p>
  <p>Written by {frontmatter.author}</p>
  <img
    src={frontmatter.image.url}
    style="max-width: 100%; height: auto;"
    alt={frontmatter.image.alt}
  />
  <p
    style="font-size: clamp(0.8rem, 0.9rem, 1rem); font-weight: 300; font-style: italic; text-align: right; margin: 0;"
  >
    {frontmatter.image.caption}
  </p>
  <slot />
  <div class="tag-list">
    {
      frontmatter.tags.map((tag: string) => (
        <p class="blog-tag">
          <a href={`/tags/${tag}`}>{tag}</a>
        </p>
      ))
    }
    <!-- {frontmatter.tags.map((tag: string) => <li class="blog-tag">{tag}</li>)} -->
  </div>
</BaseLayout>
