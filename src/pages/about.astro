---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About Me";

const identity = {
  firstName: "Juliartha",
  country: "Indonesia",
  occupation: "Creative Web Developer",
  hobbies: ["sketching", "photography", "tennis"],
};

const skills = [
  "HTML",
  "CSS",
  "JavaScript",
  "React",
  "Astro",
  "Writing Docs",
  "Figma",
  "Wireframing",
  "HiFi Design",
  "Prototyping",
];

const happy = true;
const finished = true;
const goal = 3;

const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "uppercase";
---

<BaseLayout pageTitle={pageTitle}>
  <style is:global define:vars={{ skillColor, fontWeight, textCase }}>
    /* h1 {
      color: purple;
      font-size: 4rem;
    } */
    .skill {
      color: var(--skillColor);
      font-weight: var(--fontWeight);
      text-transform: var(--textCase);
    }
  </style>
  <h1>About me</h1>
  <h2>My first live website experiment</h2>
  <p>
    I am working thorugh Astro introductory tutorial. This is my second page in
    the website.
  </p>
  <p>
    This site will be updated as I learn through the tutorial. Wish me luck!
  </p>
  <p>Here are a few facts about me:</p>
  <ul>
    <li>My name is {identity.firstName}.</li>
    <li>I live in {identity.country} and I work as a {identity.occupation}.</li>
    {
      identity.hobbies.length >= 2 && (
        <li>
          Two of my hobbies are: {identity.hobbies[1]} and {identity.hobbies[2]}
        </li>
      )
    }
  </ul>
  <p>My skills are:</p>
  <ul>
    {skills.map((skill) => <li class="skill">{skill}</li>)}
  </ul>
  {happy && <p>I am happy to learn Astro!</p>}
  {finished && <p>I finished my tutorial.</p>}
  {
    goal === 3 ? (
      <p>My goal is to finish in 3 days.</p>
    ) : (
      <p>My goal is not to finish in 3 days.</p>
    )
  }
</BaseLayout>
