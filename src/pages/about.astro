---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About Me";

const identity = {
  firstName: "Juliartha",
  country: "Bali, Indonesia",
  occupation: "Designer and Creative Web Developer",
  hobbies: ["sketching", "photography", "tennis", "reading"],
};

const skills = [
  "HTML",
  "CSS",
  "JavaScript",
  "React",
  "Astro",
  "Writing Docs",
  "Figma",
  "Wireframing",
  "HiFi Design",
  "Prototyping",
];

const happy = true;
const finished = true;
const goal = 3;

const skillColor = "coral";
const fontWeight = "medium";
const textCase = "uppercase";
---

<BaseLayout pageTitle={pageTitle}>
  <style is:global define:vars={{ skillColor, fontWeight, textCase }}>
    .skill {
      color: var(--skillColor);
      font-weight: var(--fontWeight);
      text-transform: var(--textCase);
    }
  </style>
  <h1>About me</h1>
  <h2>Designer and creative web developer who loves to solve problem through building delightful digital products.</h2>
  <p>
    I graduated with industrial engineering degree and designing products has been one of my interests. As a fresh graduate I started my career as a marketing executive in a ride-hailing start up which exposed me to digital products and user experience. Then I land my first job as UX Designer and compound various work experience across ui/ux design, user research, market research, content writing, and content design in a design/research studio.
  </p>
  <p>
    Generalist might be the word but I drawn to product-building and problem solving skills more. I have learned coding skills at school (HTML, C++, SQL) and briefly as ux designer but only at the start of 2026 that I seriously taking the time to learn (HTML, CSS, JavaScript, React) and practice it in real projects.
  </p>
  <p>My skills are:</p>
  <ul>
    {skills.map((skill) => <li class="skill">{skill}</li>)}
  </ul>
  <p>
    Outside of work, I love playing {identity.hobbies[2]} when I have the time (I used to play like five times a week) and enjoy {identity.hobbies[3]} novels at night. I also used to spend my time {identity.hobbies[0]} faces and indulging in analogue {identity.hobbies[1]}.
  </p>
</BaseLayout>
