---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import { getCollection } from "astro:content";
const allPosts = await getCollection("blog");
const pageTitle = "My Learning Blog";
---
<BaseLayout pageTitle={pageTitle}>
  <h1>Writing</h1>
  <h2>Words about my thoughts, experiences, and some of my works.</h2>
  <!-- <p>I will frequently write and post about my learning journey here!</p> -->
  <ul style="display: flex; flex-wrap: wrap; gap: 24px; padding: 0; margin: 0;">
    {allPosts.map((post: any) => <BlogPost url={`/posts/${post.id}/`} title={post.data.title} image={post.data.image.url} alt={post.data.image.alt} desc={post.data.description}/>)}
  </ul>
</BaseLayout>